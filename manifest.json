{
  "manifest_version": 3,
  "name": "Pipeline — LinkedIn Inbox CRM",
  "version": "0.1.0",
  "description": "Deal stages, notes, and follow-up reminders inside your LinkedIn inbox.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/messaging/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pipeline CRM"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
